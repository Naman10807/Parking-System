# Spring profile: dev | prod
SPRING_PROFILES_ACTIVE=prod

# Server (Render/Railway set PORT automatically)
PORT=8080

# MySQL — option A: single JDBC URL
DATABASE_URL=jdbc:mysql://host:3306/smart_parking_db?useSSL=true&serverTimezone=UTC

# MySQL — option B: individual variables
DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=smart_parking_db
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# JPA (use validate or none in production)
JPA_DDL_AUTO=validate

# JWT (required in production — min 32 characters)
JWT_SECRET=your-very-long-random-secret-key-at-least-32-characters
JWT_EXPIRATION=86400000

# CORS — your deployed frontend URL(s), comma-separated
CORS_ALLOWED_ORIGINS=https://your-app.onrender.com,https://your-app.vercel.app

# Optional: seed demo users (false in production)
SEED_DEFAULT_USERS=false

# Optional: Swagger in production
SWAGGER_UI_ENABLED=false
SWAGGER_API_DOCS_ENABLED=false

# Connection pool
DB_POOL_SIZE=10
DB_POOL_MIN_IDLE=2
